# ====== Supabase (client) ======
# คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ค่าจาก Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# ====== Supabase service role (สำหรับสคริปต์ import เท่านั้น — ห้าม commit / ห้ามใช้ฝั่ง client) ======
